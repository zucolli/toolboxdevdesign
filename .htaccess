Options -Indexes

RewriteEngine On
RewriteBase /

# 1) www → sem www (HTTPS já incluído, 1 único salto)
RewriteCond %{HTTP_HOST} ^www\.toolboxdevdesign\.com\.br$ [NC]
RewriteRule ^(.*)$ https://toolboxdevdesign.com.br/$1 [R=301,L]

# 2) Forçar HTTPS (sem www já garantido acima)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# 3) Remover trailing slash (exceto diretórios reais)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# 4) Front controller
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]
